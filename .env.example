# Server
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/tbgroup
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Admin seed (first run)
ADMIN_EMAIL=admin@tbgroup.ru
ADMIN_PASSWORD=Admin123!

# Email (Nodemailer)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@tbgroup.ru
SMTP_PASS=your-smtp-password
MAIL_FROM=TB Group <info@tbgroup.ru>
MAIL_TO=info@tbgroup.ru

# Bitrix24 CRM
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/xxxxx/
BITRIX24_LEAD_SOURCE_ID=WEB

# reCAPTCHA (optional)
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

# Client URLs
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads
